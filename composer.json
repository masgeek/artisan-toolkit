{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "masgeek/artisan-toolkit",
    "description": "A collection of custom and override Artisan commands for Laravel. Enable only what you need via a published config.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "artisan",
        "commands",
        "override",
        "toolkit",
        "schema"
    ],
    "authors": [
        {
            "name": "masgeek",
            "email": "munywelebarasa@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "13.8.0"
    },
    "autoload": {
        "psr-4": {
            "Masgeek\\ArtisanToolkit\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Masgeek\\ArtisanToolkit\\ArtisanToolkitServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
