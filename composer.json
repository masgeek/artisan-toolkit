{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "masgeek/artisan-overrides",
    "description": "Selectively override Laravel's built-in Artisan commands with safer, smarter alternatives. Enable only what you need via a published config.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "artisan",
        "commands",
        "override",
        "schema"
    ],
    "authors": [
        {
            "name": "masgeek",
            "email": "munywelebarasa@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Masgeek\\ArtisanOverrides\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Masgeek\\ArtisanOverrides\\ArtisanOverridesServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
